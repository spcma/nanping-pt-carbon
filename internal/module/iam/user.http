### {
###   "code": 200,
###   "data": {
###     "list": [
###       {
###         "id": 2033791386607685632,
###         "username": "testuser",
###         "nickname": "测试用户",
###         "avatar": "..."
###       }
###     ],
###     "total": 100
###   }
### }
### 
