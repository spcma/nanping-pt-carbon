### IAM 用户管理 API 测试

# 注意：修改为你的实际服务器地址和 Token
@host = 192.168.1.10:19870
@base_url = http://{{host}}/api
@token = 2033732340001280000

################################################################################
# 认证相关
################################################################################

### 1. 用户注册
POST {{base_url}}/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "password": "123456",
  "nickname": "测试用户"
}

###

### 2. 用户登录
POST {{base_url}}/auth/login
Content-Type: application/json

{
  "username": "testuser",
  "password": "123456"
}

###

################################################################################
# 公开查询路由（支持可选认证）
################################################################################

### 3. 获取用户列表（未认证 - 返回基础信息）
GET {{base_url}}/users?pageNum=1&pageSize=10

###

### 4. 获取用户列表（已认证 - 返回增强信息）
GET {{base_url}}/users?pageNum=1&pageSize=10
Authorization: Bearer {{token}}

###

################################################################################
# 系统用户管理路由（需要认证）
################################################################################

### 5. 创建用户
POST {{base_url}}/sys/user
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "username": "newuser",
  "nickname": "新用户",
  "password": "123456"
}

###

### 6. 获取单个用户信息
GET {{base_url}}/sys/user/1
Authorization: Bearer {{token}}

###

### 7. 更新用户信息（部分更新 - 只更新昵称）
PUT {{base_url}}/sys/user/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nickname": "新昵称"
}

###

### 8. 更新用户信息（部分更新 - 更新多个字段）
PUT {{base_url}}/sys/user/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nickname": "新昵称",
  "phone": "13800138000",
  "email": "new@example.com"
}

###

### 9. 更新用户信息（不传字段表示不更新）
PUT {{base_url}}/sys/user/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "avatar": "https://example.com/avatar.png"
  // nickname, phone, email, description 不传，表示不更新
}

###

### 10. 修改密码
PUT {{base_url}}/sys/user/1/password
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "password": "old_password",
  "newPassword": "new_password_123"
}

###

### 11. 修改用户状态
PUT {{base_url}}/sys/user/1/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "frozen"
}

###

### 12. 删除用户（逻辑删除）
DELETE {{base_url}}/sys/user/1
Authorization: Bearer {{token}}

###

### 13. 分页查询用户列表
GET {{base_url}}/sys/users?pageNum=1&pageSize=10&username=test&status=normal
Authorization: Bearer {{token}}

###

### 14. 分页查询用户列表（带排序）
GET {{base_url}}/sys/users?pageNum=1&pageSize=20&sortBy=create_time&sortOrder=desc
Authorization: Bearer {{token}}

###

################################################################################
# 错误场景测试
################################################################################

### 15. 无 Token 访问受保护接口（应返回 401）
GET {{base_url}}/sys/user/1

###

### 16. 使用无效 Token（应返回 401）
GET {{base_url}}/sys/user/1
Authorization: Bearer invalid_token

###

### 17. 创建重复用户名的用户（应返回错误）
POST {{base_url}}/sys/user
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "username": "testuser",
  "nickname": "重复用户",
  "password": "123456"
}

###

### 18. 更新不存在的用户（应返回 404）
PUT {{base_url}}/sys/user/999999
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nickname": "测试"
}

###